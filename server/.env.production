# Set these in Railway dashboard as environment variables
PORT=3001
NODE_ENV=production
API_URL=https://api.buzrig.com
CLIENT_URL=https://buzrig.com

# Railway provides DATABASE_URL automatically when you add PostgreSQL
# DATABASE_URL=postgresql://...

# Railway provides REDIS_URL automatically when you add Redis
# REDIS_URL=redis://...

JWT_SECRET=change-this-to-a-long-random-string-min-32-characters
JWT_REFRESH_SECRET=change-this-to-another-long-random-string-min-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.buzrig.com/api/auth/github/callback

OPENAI_API_KEY=
