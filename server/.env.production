# ─── Production Environment Variables ─────────────────────────────────────────
# Set these in Render dashboard (Environment tab)

PORT=3001
NODE_ENV=production
API_URL=https://api.buzrig.com
CLIENT_URL=https://buzrig.com

# Render provides DATABASE_URL automatically when you link PostgreSQL
# DATABASE_URL=postgresql://...

# Upstash Redis URL (from upstash.com dashboard)
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Generate 64-char random strings for these:
# JWT_SECRET=
# JWT_REFRESH_SECRET=

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Leave blank until you set up GitHub OAuth app
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.buzrig.com/api/auth/github/callback

# Leave blank until you add OpenAI key
OPENAI_API_KEY=
